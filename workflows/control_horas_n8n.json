      "waitBetweenTries": 5000,
      "credentials": {
        "googlePalmApi": {
          "id": "TU_CREDENTIAL_ID_GEMINI",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let respuesta = \"\";\nif (typeof $json.text === 'string') {\n  respuesta = $json.text;\n} else if ($json.content && $json.content.parts && $json.content.parts[0] && $json.content.parts[0].text) {\n  respuesta = $json.content.parts[0].text;\n} else if ($json.parts && $json.parts[0] && $json.parts[0].text) {\n  respuesta = $json.parts[0].text;\n} \n\nif (respuesta) {\n  try {\n    if (respuesta.includes(\"TEXTO_NO_VALIDO\")) {\n      throw new Error(\"Imagen no reconocida como cuadrante\");\n    }\n\n    respuesta = respuesta.replace('```json', '').replace('
```', '').trim();\n    let datos = JSON.parse(respuesta);\n\n    const dias = ['lunes', 'martes', 'miercoles', 'jueves', 'viernes', 'sabado', 'domingo'];\n    let acumuladorTotal = 0;\n    let tieneHoras = false;\n\n    for (let dia of dias) {\n      let horas = datos[dia] || 0;\n      if (horas > 0) tieneHoras = true;\n\n      if (horas > 8) {\n        horas = horas - 0.5;\n      } else if (horas > 6) {\n        horas = horas - 0.25;\n      } \n      datos[dia] = horas;\n      acumuladorTotal += horas; // 🌟 CORREGIDO: Ahora suma 'horas' correctamente\n    }\n\n    if (!tieneHoras && (datos.rango_fecha.includes(\"ej:\") || datos.rango_fecha === \"\")) {\n      throw new Error(\"Cuadrante vacío o falso\");\n    }\n\n    return {\n      \"resultado\": \"ok\", \n      \"Fecha Inicio\": datos.rango_fecha || \"Ver cuadrante\",\n      \"Lunes\": datos.lunes,\n      \"Martes \": datos.martes,      \n      \"Miercoles\": datos.miercoles,\n      \"Jueves\": datos.jueves,\n      \"Viernes \": datos.viernes,    \n      \"Sabado \": datos.sabado,      \n      \"Domingo\": datos.domingo,\n      \"Total horas\": acumuladorTotal\n    };\n\n  } catch (e) {\n    return {\n      \"resultado\": \"error\",\n      \"motivo\": \"La imagen no contiene un cuadrante de turnos válido.\"\n    };\n  }\n}\n\nreturn { \"resultado\": \"error\", \"motivo\": \"Sin respuesta\" };"
      },
