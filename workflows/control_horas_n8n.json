      "parameters": {
        "jsCode": "let respuesta = \"\";\n\nif (typeof $json.text === 'string') {\n  respuesta = $json.text;\n} else if ($json.content && $json.content.parts && $json.content.parts[0] && $json.content.parts[0].text) {\n  respuesta = $json.content.parts[0].text;\n} else if ($json.output && typeof $json.output === 'string') {\n  respuesta = $json.output;\n}\n\n// Función interna para moldear el objeto igual que las columnas del Excel\nfunction mapearAExcel(item) {\n  let fechaFormateada = item.fecha;\n  if (fechaFormateada && fechaFormateada.includes('-')) {\n    fechaFormateada = fechaFormateada.split('-').reverse().join('/');\n  }\n  \n  // 🌟 CLAVE: Las llaves se llaman EXACTAMENTE como tus columnas (Mayúsculas)\n  return {\n    \"Fecha\": fechaFormateada || \"\",\n    \"Horas Normales\": item.horas_normales ?? 0,\n    \"Horas Extra\": item.horas_extra ?? 0,\n    \"Notas\": item.notas || \"\"\n  };\n}\n\nif (respuesta) {\n  try {\n    respuesta = respuesta.replace('```json', '').replace('```', '').trim();\n    let datos = JSON.parse(respuesta);\n    \n    let lista = [];\n    if (datos.registro && Array.isArray(datos.registro)) {\n      lista = datos.registro;\n    } else if (Array.isArray(datos)) {\n      lista = datos;\n    } else {\n      lista = [datos];\n    }\n    \n    return lista.map(item => mapearAExcel(item));\n\n  } catch (e) {\n    return [{ \"error\": true, \"motivo\": \"No se pudo parsear el texto de Groq\" }];\n  }\n}\n\nif ($json.registro && Array.isArray($json.registro)) {\n  return $json.registro.map(item => mapearAExcel(item));\n}\n\nreturn $json;"
      },
